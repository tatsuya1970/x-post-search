{
  "name": "x-post-search",
  "version": "0.1.0",
  "private": true,
  "main": "main/main.js",
  "author": "",
  "description": "Xの投稿を検索してCSV形式で保存するツール",
  "build": {
    "appId": "com.xpostsearch.app",
    "productName": "X Post Search",
    "files": [
      "main/**/*",
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:electron": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "next build && electron-builder",
    "build:mac": "next build && electron-builder --mac",
    "build:mac:unsigned": "next build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "electron-serve": "^3.0.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "oauth-1.0a": "^2.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
